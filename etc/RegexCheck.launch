<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<launchConfiguration type="org.eclipse.jdt.launching.localJavaApplication">
<listAttribute key="org.eclipse.debug.core.MAPPED_RESOURCE_PATHS">
<listEntry value="/jelmilter/src/de/ovgu/cs/jelmilter/RegexCheck.java"/>
</listAttribute>
<listAttribute key="org.eclipse.debug.core.MAPPED_RESOURCE_TYPES">
<listEntry value="1"/>
</listAttribute>
<booleanAttribute key="org.eclipse.debug.core.appendEnvironmentVariables" value="true"/>
<stringAttribute key="org.eclipse.jdt.launching.MAIN_TYPE" value="de.ovgu.cs.jelmilter.RegexCheck"/>
<stringAttribute key="org.eclipse.jdt.launching.PROGRAM_ARGUMENTS" value="/tmp/spam ${workspace_loc}/jelmilter/etc/regex.conf"/>
<stringAttribute key="org.eclipse.jdt.launching.PROJECT_ATTR" value="jelmilter"/>
<stringAttribute key="org.eclipse.jdt.launching.VM_ARGUMENTS" value="-Dbla=${workspace_loc}/jelmilter/etc/regex.conf"/>
</launchConfiguration>
